-- БУГА БУГА: ПЛАВНАЯ KILL AURA (БЫСТРЕЕ ЦЕЛИ)
local player = game.Players.LocalPlayer
local userInputService = game:GetService("UserInputService")
local runService = game:GetService("RunService")

-- НАСТРОЙКИ
local settings = {
    enabled = true,
    range = 15,
    toggleKey = Enum.KeyCode.K,
    walkSpeed = 24  -- скорость нашего персонажа (если у цели 16-18, то 24 хватит)
}

local waitingForKey = false
local character = nil
local humanoid = nil
local humanoidRootPart = nil

-- ФУНКЦИЯ ПРИМЕНЕНИЯ СКОРОСТИ
local function applySpeed()
    if character and humanoid then
        humanoid.WalkSpeed = settings.walkSpeed
    end
end

-- ПЕРЕЗАГРУЗКА ПОСЛЕ СМЕРТИ
local function onCharacterAdded(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    wait(0.2)
    applySpeed()
    print("Килл-аура перезапущена, скорость " .. settings.walkSpeed)
end

-- ЗАПУСК
character = player.Character or player.CharacterAdded:wait()
humanoid = character:WaitForChild("Humanoid")
humanoidRootPart = character:WaitForChild("HumanoidRootPart")
player.CharacterAdded:Connect(onCharacterAdded)
applySpeed()

-- ПОИСК БЛИЖАЙШЕГО ПРОТИВНИКА
local function getClosestTarget()
    if not character or not humanoidRootPart then return nil end
    local closest = nil
    local shortestDist = settings.range
    for _, target in pairs(game.Players:GetPlayers()) do
        if target ~= player and target.Character then
            local targetChar = target.Character
            local targetHumanoid = targetChar:FindFirstChild("Humanoid")
            local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
            if targetHumanoid and targetHumanoid.Health > 0 and targetRoot then
                local dist = (humanoidRootPart.Position - targetRoot.Position).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closest = target
                end
            end
        end
    end
    return closest
end

-- ОСНОВНОЙ ЦИКЛ (ЧЕРЕЗ HEARTBEAT ДЛЯ ПЛАВНОСТИ)
local currentTarget = nil
local attackCooldown = 0

runService.Heartbeat:Connect(function(deltaTime)
    if not settings.enabled then return end
    if not character or not character.Parent then return end
    if not humanoid or not humanoidRootPart then return end
    
    -- ОБНОВЛЯЕМ СКОРОСТЬ НА ВСЯКИЙ СЛУЧАЙ
    humanoid.WalkSpeed = settings.walkSpeed
    
    currentTarget = getClosestTarget()
    
    if currentTarget and currentTarget.Character then
        local targetRoot = currentTarget.Character:FindFirstChild("HumanoidRootPart")
        local targetHumanoid = currentTarget.Character:FindFirstChild("Humanoid")
        
        if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
            local targetPos = targetRoot.Position
            local myPos = humanoidRootPart.Position
            local distance = (myPos - targetPos).Magnitude
            
            if distance <= settings.range then
                -- ПОЗИЦИЯ ЗА СПИНОЙ ЦЕЛИ (на 2.5 студа)
                local targetCFrame = targetRoot.CFrame
                local behindTarget = targetCFrame.Position - targetCFrame.LookVector * 2.5
                
                -- ПЛАВНОЕ ДВИЖЕНИЕ К ПОЗИЦИИ ЗА СПИНОЙ
                humanoid:MoveTo(behindTarget)
                
                -- АТАКА (КАЖДЫЕ 0.1 СЕКУНДЫ)
                if tick() - attackCooldown > 0.1 then
                    attackCooldown = tick()
                    
                    local tool = character:FindFirstChildOfClass("Tool")
                    if tool then
                        tool:Activate()
                    else
                        local damageEvent = game:GetService("ReplicatedStorage"):FindFirstChild("DamageEvent")
                        if damageEvent then
                            damageEvent:FireServer(targetRoot)
                        end
                    end
                end
            end
        end
    end
end)

-- UI
if player.PlayerGui:FindFirstChild("KillAuraUI") then
    player.PlayerGui:FindFirstChild("KillAuraUI"):Destroy()
end

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "KillAuraUI"
screenGui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 140, 0, 95)
frame.Position = UDim2.new(0.02, 0, 0.8, 0)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BackgroundTransparency = 0.2
frame.BorderSizePixel = 1
frame.BorderColor3 = Color3.fromRGB(255, 100, 100)
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, 0, 0, 20)
title.Text = settings.enabled and "KILL AURA [ON]" or "KILL AURA [OFF]"
title.TextColor3 = settings.enabled and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,100,100)
title.BackgroundTransparency = 1
title.TextSize = 11

local speedLabel = Instance.new("TextLabel", frame)
speedLabel.Size = UDim2.new(0.5, 0, 0, 15)
speedLabel.Position = UDim2.new(0, 0, 0, 22)
speedLabel.Text = "Speed: " .. settings.walkSpeed
speedLabel.BackgroundTransparency = 1
speedLabel.TextColor3 = Color3.fromRGB(200,200,200)
speedLabel.TextSize = 10

local speedBox = Instance.new("TextBox", frame)
speedBox.Size = UDim2.new(0.4, 0, 0, 15)
speedBox.Position = UDim2.new(0.55, 0, 0, 22)
speedBox.Text = tostring(settings.walkSpeed)
speedBox.BackgroundColor3 = Color3.fromRGB(50,50,50)
speedBox.TextColor3 = Color3.fromRGB(255,255,255)
speedBox.TextSize = 10

local rangeLabel = Instance.new("TextLabel", frame)
rangeLabel.Size = UDim2.new(0.5, 0, 0, 15)
rangeLabel.Position = UDim2.new(0, 0, 0, 40)
rangeLabel.Text = "Range: " .. settings.range
rangeLabel.BackgroundTransparency = 1
rangeLabel.TextColor3 = Color3.fromRGB(200,200,200)
rangeLabel.TextSize = 10

local rangeBox = Instance.new("TextBox", frame)
rangeBox.Size = UDim2.new(0.4, 0, 0, 15)
rangeBox.Position = UDim2.new(0.55, 0, 0, 40)
rangeBox.Text = tostring(settings.range)
rangeBox.BackgroundColor3 = Color3.fromRGB(50,50,50)
rangeBox.TextColor3 = Color3.fromRGB(255,255,255)
rangeBox.TextSize = 10

local keyButton = Instance.new("TextButton", frame)
keyButton.Size = UDim2.new(0.9, 0, 0, 18)
keyButton.Position = UDim2.new(0.05, 0, 0, 60)
keyButton.Text = "Key: " .. tostring(settings.toggleKey):gsub("Enum.KeyCode.", "")
keyButton.BackgroundColor3 = Color3.fromRGB(60,60,60)
keyButton.TextColor3 = Color3.fromRGB(255,255,255)
keyButton.TextSize = 9

-- ОБНОВЛЕНИЕ UI
local function refreshUI()
    title.Text = settings.enabled and "KILL AURA [ON]" or "KILL AURA [OFF]"
    title.TextColor3 = settings.enabled and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,100,100)
    speedLabel.Text = "Speed: " .. settings.walkSpeed
    rangeLabel.Text = "Range: " .. settings.range
    keyButton.Text = "Key: " .. tostring(settings.toggleKey):gsub("Enum.KeyCode.", "")
end

-- НАСТРОЙКА СКОРОСТИ
speedBox.FocusLost:Connect(function()
    local num = tonumber(speedBox.Text)
    if num then
        settings.walkSpeed = num
        applySpeed()
        refreshUI()
    else
        speedBox.Text = tostring(settings.walkSpeed)
    end
end)

-- ДАЛЬНОСТЬ
rangeBox.FocusLost:Connect(function()
    local num = tonumber(rangeBox.Text)
    if num then
        settings.range = num
        refreshUI()
    else
        rangeBox.Text = tostring(settings.range)
    end
end)

-- КЕЙБИНД
keyButton.MouseButton1Click:Connect(function()
    waitingForKey = true
    keyButton.Text = "Press key..."
    keyButton.BackgroundColor3 = Color3.fromRGB(200,50,50)
end)

userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if waitingForKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            settings.toggleKey = input.KeyCode
            refreshUI()
            keyButton.BackgroundColor3 = Color3.fromRGB(60,60,60)
            waitingForKey = false
        end
        return
    end
    
    if input.KeyCode == settings.toggleKey then
        settings.enabled = not settings.enabled
        refreshUI()
        if not settings.enabled then
            humanoid:MoveTo(humanoidRootPart.Position)
        end
    end
end)

refreshUI()
print("Плавная Kill Aura загружена. Скорость " .. settings.walkSpeed .. ". Нажми " .. tostring(settings.toggleKey):gsub("Enum.KeyCode.", "") .. " для вкл/выкл.")
