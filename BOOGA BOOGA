local function refreshUI()
    title.Text = settings.enabled and "ORBIT [ON]" or "ORBIT [OFF]"
    title.TextColor3 = settings.enabled and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,100,100)
    speedLabel.Text = "Speed: " .. settings.walkSpeed
    radiusLabel.Text = "Radius: " .. settings.orbitRadius
    rangeLabel.Text = "Range: " .. settings.range
    keyButton.Text = "Key: " .. tostring(settings.toggleKey):gsub("Enum.KeyCode.", "")
end

speedBox.FocusLost:Connect(function()
    local num = tonumber(speedBox.Text)
    if num then settings.walkSpeed = num; applySpeed(); refreshUI()
    else speedBox.Text = tostring(settings.walkSpeed) end
end)

radiusBox.FocusLost:Connect(function()
    local num = tonumber(radiusBox.Text)
    if num then settings.orbitRadius = num; refreshUI()
    else radiusBox.Text = tostring(settings.orbitRadius) end
end)

rangeBox.FocusLost:Connect(function()
    local num = tonumber(rangeBox.Text)
    if num then settings.range = num; refreshUI()
    else rangeBox.Text = tostring(settings.range) end
end)

keyButton.MouseButton1Click:Connect(function()
    waitingForKey = true
    keyButton.Text = "Press key..."
    keyButton.BackgroundColor3 = Color3.fromRGB(200,50,50)
end)

userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if waitingForKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            settings.toggleKey = input.KeyCode
            refreshUI()
            keyButton.BackgroundColor3 = Color3.fromRGB(60,60,60)
            waitingForKey = false
        end
        return
    end
    if input.KeyCode == settings.toggleKey then
        settings.enabled = not settings.enabled
        refreshUI()
    end
end)

refreshUI()
print("Непрерывное хождение вокруг цели! Персонаж постоянно идёт по кругу, не останавливаясь.")
