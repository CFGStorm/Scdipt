infoLabel.BackgroundTransparency = 1
infoLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
infoLabel.TextSize = 9

local function refreshUI()
    title.Text = _G.KillAuraEnabled and "KILL AURA [ON]" or "KILL AURA [OFF]"
    title.TextColor3 = _G.KillAuraEnabled and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,100,100)
    rangeLabel.Text = "Range: " .. _G.KillAuraRange
    speedLabel.Text = "Attack Speed: " .. _G.AttackSpeed
    keyButton.Text = "⚙️ Set Keybind: " .. tostring(_G.ToggleKey):gsub("Enum.KeyCode.", "")
end

rangeBox.FocusLost:Connect(function()
    local num = tonumber(rangeBox.Text)
    if num then _G.KillAuraRange = num; refreshUI()
    else rangeBox.Text = tostring(_G.KillAuraRange) end
end)

speedBox.FocusLost:Connect(function()
    local num = tonumber(speedBox.Text)
    if num then _G.AttackSpeed = num; refreshUI()
    else speedBox.Text = tostring(_G.AttackSpeed) end
end)

-- НАСТРОЙКА КЕЙБИНДА (ЖМИ НА КНОПКУ И ПОТОМ НА ЛЮБУЮ КЛАВИШУ)
keyButton.MouseButton1Click:Connect(function()
    waitingForKey = true
    keyButton.Text = "🎯 Press ANY key now..."
    keyButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
end)

userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- НАСТРОЙКА КЕЙБИНДА
    if waitingForKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            _G.ToggleKey = input.KeyCode
            refreshUI()
            keyButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            waitingForKey = false
        end
        return
    end
    
    -- ВКЛ/ВЫКЛ КИЛЛ АУРЫ
    if input.KeyCode == _G.ToggleKey then
        _G.KillAuraEnabled = not _G.KillAuraEnabled
        refreshUI()
    end
end)

refreshUI()
