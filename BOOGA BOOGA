-- БУГА БУГА: ПЛАВНАЯ KILL AURA + НАСТРАИВАЕМЫЙ КЕЙБИНД
local player = game.Players.LocalPlayer
local userInputService = game:GetService("UserInputService")
local runService = game:GetService("RunService")

-- НАСТРОЙКИ (ПО УМОЛЧАНИЮ)
_G.KillAuraEnabled = true
_G.KillAuraRange = 15
_G.AttackSpeed = 0.25
_G.ToggleKey = Enum.KeyCode.K  -- КЛАВИША ПО УМОЛЧАНИЮ K

local waitingForKey = false
local character = nil
local humanoid = nil
local humanoidRootPart = nil

-- ПЕРЕЗАГРУЗКА ПЕРСОНАЖА
local function onCharacterAdded(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    wait(0.3)
end

-- ЗАПУСК
character = player.Character or player.CharacterAdded:wait()
humanoid = character:WaitForChild("Humanoid")
humanoidRootPart = character:WaitForChild("HumanoidRootPart")
player.CharacterAdded:Connect(onCharacterAdded)

-- ПОИСК БЛИЖАЙШЕГО ПРОТИВНИКА
local function getClosestTarget()
    if not character or not humanoidRootPart then return nil end
    local closest = nil
    local shortestDist = _G.KillAuraRange
    for _, target in pairs(game.Players:GetPlayers()) do
        if target ~= player and target.Character then
            local targetChar = target.Character
            local targetHumanoid = targetChar:FindFirstChild("Humanoid")
            local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
            if targetHumanoid and targetHumanoid.Health > 0 and targetRoot then
                local dist = (humanoidRootPart.Position - targetRoot.Position).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closest = target
                end
            end
        end
    end
    return closest
end

-- ОСНОВНОЙ ЦИКЛ
local attackCooldown = 0

runService.Heartbeat:Connect(function()
    if not _G.KillAuraEnabled then return end
    if not character or not character.Parent then return end
    if not humanoid or not humanoidRootPart then return end
    
    local target = getClosestTarget()
    
    if target and target.Character then
        local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
        local targetHumanoid = target.Character:FindFirstChild("Humanoid")
        
        if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
            local targetPos = targetRoot.Position
            local myPos = humanoidRootPart.Position
            local distance = (myPos - targetPos).Magnitude
            
            if distance <= _G.KillAuraRange then
                -- ПЛАВНОЕ ДВИЖЕНИЕ ЗА СПИНУ
                local targetCFrame = targetRoot.CFrame
                local behindTarget = targetCFrame.Position - targetCFrame.LookVector * 3.5
                humanoid:MoveTo(behindTarget)
                
                -- АТАКА
                if tick() - attackCooldown > _G.AttackSpeed then
                    attackCooldown = tick()
                    local tool = character:FindFirstChildOfClass("Tool")
                    if tool then
                        tool:Activate()
                    else
                        local damageEvent = game:GetService("ReplicatedStorage"):FindFirstChild("DamageEvent")
                        if damageEvent then
                            damageEvent:FireServer(targetRoot)
                        end
                    end
                end
            end
        end
    end
end)

